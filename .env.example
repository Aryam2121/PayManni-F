# PayManni Frontend Environment Variables
# Host only — do NOT include https:// prefix

# Local development
# VITE_BACKEND=localhost:8000

# Production (Vercel) — set to your deployed backend host, e.g. api.paymanni.com or your-app.onrender.com
VITE_BACKEND=your-production-api-host.com

VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
VITE_GOOGLE_CLIENT_ID=your_google_client_id
